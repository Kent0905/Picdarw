    <div id="imageModal" class="fixed inset-0 bg-black/90 z-[6000] hidden items-center justify-center cursor-zoom-out opacity-0 transition-opacity duration-300" onclick="this.classList.add('opacity-0'); setTimeout(() => this.classList.replace('flex', 'hidden'), 300)">
        <img id="imageModalSrc" src="" class="max-w-[90vw] max-h-[90vh] object-contain shadow-2xl rounded" />
    </div>

    <div id="loading" class="fixed inset-0 bg-slate-900/90 backdrop-blur-sm flex items-center justify-center z-[2000] hidden">
        <div class="text-center">
            <div class="w-14 h-14 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin mx-auto mb-6"></div>
            <p class="text-white font-black tracking-widest text-xl" id="loadingTitle">處理中...</p>
            <p class="text-slate-400 text-xs mt-3 font-mono uppercase" id="loadingText">Please wait</p>
            <div id="batchProgress" class="mt-6 w-64 bg-slate-800 rounded-full h-1.5 overflow-hidden hidden mx-auto">
                <div id="batchProgressBar" class="bg-indigo-500 h-full w-0 transition-all duration-300"></div>
            </div>
        </div>
    </div>
    <div id="toastContainer" class="fixed bottom-[96px] right-6 z-[4000] flex flex-col gap-3 pointer-events-none"></div>
    <input type="file" id="configInput" accept=".json" class="hidden"/>
    <div id="customTooltip"></div>

    <script>
        const apiKey = ""; 
        const imageInput = document.getElementById('imageInput'), configInput = document.getElementById('configInput');
        const canvas = document.getElementById('imageCanvas'), ctx = canvas.getContext('2d'), overlayLayer = document.getElementById('overlayLayer'), imageWrapper = document.getElementById('imageWrapper');
        const detectionTableBody = document.getElementById('detectionTableBody'), batchList = document.getElementById('batchList');
        const btnScan = document.getElementById('btnScan'), btnExtract = document.getElementById('btnExtract');
        const loading = document.getElementById('loading'), canvasArea = document.getElementById('canvasArea'), tooltip = document.getElementById('customTooltip');
        const aiBadge = document.getElementById('aiBadge');

        // === HUD Blueprint 教學 ===
        const helpLogoBtn = document.getElementById('helpLogoBtn');
        const showHints = () => { document.body.classList.add('show-hints'); };
        const hideHints = () => { document.body.classList.remove('show-hints'); };
        
        helpLogoBtn.addEventListener('mousedown', showHints);
        window.addEventListener('mouseup', hideHints);
        helpLogoBtn.addEventListener('touchstart', (e) => { e.preventDefault(); showHints(); }, {passive: false});
        window.addEventListener('touchend', hideHints);

        // Drawer States
        let isLeftDrawerOpen = true;
        document.getElementById('leftDrawerToggle').onclick = () => {
            isLeftDrawerOpen = !isLeftDrawerOpen;
            const drawer = document.getElementById('leftDrawer'), icon = document.getElementById('leftDrawerIcon');
            if (isLeftDrawerOpen) { 
                drawer.classList.remove('-translate-x-full'); 
                icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>`; 
                canvasArea.style.left = '320px';
            } 
            else { 
                drawer.classList.add('-translate-x-full'); 
                icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>`; 
                canvasArea.style.left = '0';
            }
        };

        let isBottomDrawerOpen = false;
        document.getElementById('bottomDrawerToggle').onclick = () => {
            isBottomDrawerOpen = !isBottomDrawerOpen;
            const drawer = document.getElementById('bottomDrawer'), icon = document.getElementById('bottomDrawerIcon');
            if (isBottomDrawerOpen) { drawer.classList.remove('translate-y-full'); icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path>`; } 
            else { drawer.classList.add('translate-y-full'); icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 15l7-7 7 7"></path>`; }
        };

        // Workspace States
        let referenceImg = new Image(), detectedBlocks = [], backgroundAnchors = [], batchFiles = [], batchResults = [];   
        let currentSingleBase64 = "", currentSingleFileName = "", currentFileIndex = -1, tooltipTimeout;
        let undoStack = [], redoStack = []; let clipboard = [];

        function saveState() { undoStack.push(JSON.parse(JSON.stringify(detectedBlocks))); if (undoStack.length > 20) undoStack.shift(); redoStack = []; }
        function undo() { if (undoStack.length > 0) { redoStack.push(JSON.parse(JSON.stringify(detectedBlocks))); detectedBlocks = undoStack.pop(); reassignIDs(); updateUI(); showToast("復原上一步"); } }
        function redo() { if (redoStack.length > 0) { undoStack.push(JSON.parse(JSON.stringify(detectedBlocks))); detectedBlocks = redoStack.pop(); reassignIDs(); updateUI(); showToast("重做下一步"); } }

        let currentZoom = 1.0, toolMode = 'select', previousToolMode = 'select', selectedBlockIds = new Set();
        let isDragging = false, isDrawing = false, isResizing = false, isMarqueeSelecting = false;
        let dragStartCoords = null, originalBlocksState = null, drawTempDiv = null, resizeDir = '', resizingMarkerId = null;
        let actionStateSaved = false;

        // ====== 專業線性 SVG 圖示產生器 ======
        const getIconSVG = (type, cls = "w-4 h-4") => {
            const base = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="${cls}">`;
            switch(type) {
                case 'text': return base + `<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`;
                case 'image': return base + `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
                case 'screenshot': return base + `<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`;
                case 'range': return base + `<circle cx="12" cy="12" r="3"/><path d="M3 12h3"/><path d="M18 12h3"/><path d="M12 3v3"/><path d="M12 18v3"/></svg>`;
                case 'mask': return base + `<circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>`;
                case 'box': return base + `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/></svg>`;
                case 'all': return base + `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="12" cy="12" r="3"/></svg>`;
                case 'check': return base + `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
                case 'cross': return base + `<circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`;
                case 'info': return base + `<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>`;
                default: return base + `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>`;
            }
        };

        function getTypeString(type) {
            switch(type) { case 'text': return '文字'; case 'image': return '圖片'; case 'screenshot': return '截圖'; default: return '文字'; }
        }

        function showToast(msg, type='info') {
            const t = document.createElement('div');
            let bg = type==='error'?'bg-red-500 border-red-600':type==='warning'?'bg-amber-500 border-amber-600':type==='success'?'bg-emerald-500 border-emerald-600':'bg-slate-800 border-slate-600';
            let iconType = type === 'success' ? 'check' : type === 'error' ? 'cross' : 'info';
            let icon = getIconSVG(iconType, 'w-4 h-4 shrink-0 opacity-80');
            t.className = `${bg} text-white border px-4 py-3 rounded-xl shadow-2xl text-xs font-bold flex items-center gap-2 transition-all translate-y-10 opacity-0 pointer-events-auto max-w-sm`;
            t.innerHTML = `${icon}<span>${msg}</span>`; 
            document.getElementById('toastContainer').appendChild(t);
            requestAnimationFrame(() => t.classList.remove('translate-y-10', 'opacity-0'));
            setTimeout(() => { t.classList.add('translate-y-10', 'opacity-0'); setTimeout(() => t.remove(), 300); }, 5000);
        }

        // ====== 快速切換類型選單 ======
        let activeMenuId = null;
        window.showTypeMenu = (e, id) => {
            e.preventDefault(); e.stopPropagation();
            if(!selectedBlockIds.has(id)){ selectedBlockIds.clear(); selectedBlockIds.add(id); updateSelectionUI(); }
            activeMenuId = id;
            const menu = document.getElementById('quickTypeMenu');
            const rx = Math.min(e.clientX, window.innerWidth - 120);
            const ry = Math.min(e.clientY + 10, window.innerHeight - 150);
            menu.style.left = rx + 'px'; menu.style.top = ry + 'px';
            menu.classList.remove('hidden'); menu.classList.add('flex');
        };
        window.addEventListener('mousedown', (e) => {
            if (!e.target.closest('#quickTypeMenu')) { document.getElementById('quickTypeMenu').classList.add('hidden'); document.getElementById('quickTypeMenu').classList.remove('flex'); }
            if (!e.target.closest('#rangeTypeMenu')) { document.getElementById('rangeTypeMenu').classList.add('hidden'); document.getElementById('rangeTypeMenu').classList.remove('flex'); }
        });
        window.setQuickType = (type) => {
            if(activeMenuId !== null) {
                saveState();
                detectedBlocks.forEach(b => { if(selectedBlockIds.has(b.id) && !b.isSystemZone) b.dataType = type; });
                document.getElementById('quickTypeMenu').classList.add('hidden'); document.getElementById('quickTypeMenu').classList.remove('flex');
                renderMarkers(); renderTable(); updateActionBtnState();
                showToast(`已切換為 ${getTypeString(type)} 類型`, 'success');
            }
        };

        // ====== 辨識區類型切換邏輯 ======
        let activeRangeId = null;
        window.showRangeMenu = (e, idStr) => {
            e.preventDefault(); e.stopPropagation();
            activeRangeId = idStr;
            const menu = document.getElementById('rangeTypeMenu');
            const rx = Math.min(e.clientX, window.innerWidth - 140);
            const ry = Math.min(e.clientY + 10, window.innerHeight - 150);
            menu.style.left = rx + 'px'; menu.style.top = ry + 'px';
            menu.classList.remove('hidden'); menu.classList.add('flex');
        };
        window.setRangeType = (type) => {
            if(activeRangeId !== null) {
                saveState();
                let block = detectedBlocks.find(b => b.id === activeRangeId);
                if (block) block.targetType = type;
                document.getElementById('rangeTypeMenu').classList.add('hidden'); document.getElementById('rangeTypeMenu').classList.remove('flex');
                renderMarkers();
                let typeName = type === 'text' ? '文字' : (type === 'image' ? '圖片' : '全部');
                showToast(`辨識區限定為: ${typeName}`, 'success');
            }
        };

        function reassignIDs() {
            const newSelectedIds = new Set();
            let newId = 1;
            detectedBlocks.forEach((b) => { 
                if (b.isSystemZone) {
                    if (selectedBlockIds.has(b.id)) newSelectedIds.add(b.id);
                } else {
                    if (selectedBlockIds.has(b.id)) newSelectedIds.add(newId); 
                    const isAutoNamed = b.isManuallyNamed === false || (b.isManuallyNamed === undefined && b.columnName === String(b.id));
                    if (!b.columnName || isAutoNamed) { b.columnName = String(newId); b.isManuallyNamed = false; }
                    b.id = newId; 
                    newId++;
                }
            });
            selectedBlockIds = newSelectedIds;
        }

        document.getElementById('themeToggleBtn').onclick = () => { document.documentElement.classList.toggle('dark'); };
        document.getElementById('tabFields').onclick = () => switchTab('fields'); document.getElementById('tabBatch').onclick = () => switchTab('batch');
        function switchTab(mode) {
            document.getElementById('panelFields').classList.toggle('hidden', mode !== 'fields'); document.getElementById('panelBatch').classList.toggle('hidden', mode === 'fields');
            document.getElementById('tabFields').className = mode==='fields' ? "flex-1 p-3 border-b-2 border-indigo-600 text-indigo-600 bg-white dark:bg-slate-800/50" : "flex-1 p-3 border-b-2 border-transparent hover:bg-slate-50 bg-white dark:bg-slate-900";
            document.getElementById('tabBatch').className = mode==='batch' ? "flex-1 p-3 border-b-2 border-indigo-600 text-indigo-600 bg-white dark:bg-slate-800/50" : "flex-1 p-3 border-b-2 border-transparent hover:bg-slate-50 bg-white dark:bg-slate-900";
        }

        const toolSelect = document.getElementById('toolSelect'), toolPan = document.getElementById('toolPan'), toolDraw = document.getElementById('toolDraw');
        
        document.getElementById('menuDraw').onclick = () => setToolMode('draw');
        document.getElementById('menuDrawRange').onclick = () => setToolMode('draw-range');
        document.getElementById('menuDrawMask').onclick = () => setToolMode('draw-mask');
        toolSelect.onclick = () => setToolMode('select'); toolPan.onclick = () => setToolMode('pan'); 
        
        let previousDrawMode = 'draw';
        toolDraw.onclick = () => { if (!toolMode.startsWith('draw')) setToolMode(previousDrawMode); };

        document.getElementById('toolDuplicate').onclick = duplicateSelected; document.getElementById('toolDelete').onclick = deleteSelected;
        
        document.getElementById('toolLockToggle').onclick = () => { 
            if (selectedBlockIds.size === 0) return; const selectedBlocks = detectedBlocks.filter(b => selectedBlockIds.has(b.id)); const allLocked = selectedBlocks.every(b => b.isLocked);
            setLockStateSelected(!allLocked);
        };

        function setLockStateSelected(lockState) {
            if (selectedBlockIds.size === 0) return; saveState(); let changed = false;
            detectedBlocks.forEach(b => { if (selectedBlockIds.has(b.id) && b.isLocked !== lockState) { b.isLocked = lockState; changed = true; } });
            if (changed) { renderMarkers(); updateSelectionUI(); showToast(lockState ? "已鎖定物件" : "已解鎖物件", "success"); }
        }

        function setToolMode(mode) {
            toolMode = mode; canvasArea.className = `canvas-area absolute top-0 bottom-0 right-0 z-0 p-10 flex mode-${mode} transition-all duration-300`;
            
            if (mode.startsWith('draw')) previousDrawMode = mode;

            [toolSelect, toolPan, toolDraw].forEach(btn => {
                btn.classList.remove('bg-indigo-100', 'text-indigo-600', 'dark:bg-indigo-900/60', 'dark:text-indigo-400', 'shadow-inner', 'text-slate-500', 'hover:bg-slate-200', 'dark:hover:bg-slate-700', 'text-red-500', 'hover:text-red-500', 'bg-red-50', 'dark:text-red-400', 'dark:bg-red-900/40', 'text-slate-800', 'bg-slate-200', 'dark:text-white', 'dark:bg-slate-700');
            });

            if (mode === 'select') {
                toolSelect.classList.add('bg-indigo-100', 'text-indigo-600', 'dark:bg-indigo-900/60', 'dark:text-indigo-400', 'shadow-inner');
                toolPan.classList.add('text-slate-500', 'hover:bg-slate-200', 'dark:hover:bg-slate-700');
                toolDraw.classList.add('text-slate-500', 'hover:bg-slate-200', 'dark:hover:bg-slate-700');
            } else if (mode === 'pan') {
                toolPan.classList.add('bg-indigo-100', 'text-indigo-600', 'dark:bg-indigo-900/60', 'dark:text-indigo-400', 'shadow-inner');
                toolSelect.classList.add('text-slate-500', 'hover:bg-slate-200', 'dark:hover:bg-slate-700');
                toolDraw.classList.add('text-slate-500', 'hover:bg-slate-200', 'dark:hover:bg-slate-700');
            } else if (mode.startsWith('draw')) {
                toolSelect.classList.add('text-slate-500', 'hover:bg-slate-200', 'dark:hover:bg-slate-700');
                toolPan.classList.add('text-slate-500', 'hover:bg-slate-200', 'dark:hover:bg-slate-700');
                
                const drawIcon = document.getElementById('toolDrawIcon');
                if(mode === 'draw-range') {
                    toolDraw.classList.add('text-red-500', 'bg-red-50', 'dark:text-red-400', 'dark:bg-red-900/40', 'shadow-inner');
                    drawIcon.innerHTML = `<circle cx="12" cy="12" r="3"/><path d="M3 12h3"/><path d="M18 12h3"/><path d="M12 3v3"/><path d="M12 18v3"/>`;
                } else if(mode === 'draw-mask') {
                    toolDraw.classList.add('text-slate-800', 'bg-slate-200', 'dark:text-white', 'dark:bg-slate-700', 'shadow-inner');
                    drawIcon.innerHTML = `<circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>`;
                } else {
                    toolDraw.classList.add('bg-indigo-100', 'text-indigo-600', 'dark:bg-indigo-900/60', 'dark:text-indigo-400', 'shadow-inner');
                    drawIcon.innerHTML = `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>`;
                }
            }
            if (mode.startsWith('draw')) { selectedBlockIds.clear(); updateSelectionUI(); }
        }

        window.addEventListener('keydown', (e) => {
            if(e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
            
            if (selectedBlockIds.size > 0 && !e.ctrlKey && !e.altKey && !e.metaKey && ['1','2','3'].includes(e.key)) {
                e.preventDefault(); saveState();
                const typeMap = {'1': 'text', '2': 'image', '3': 'screenshot'};
                let changed = false;
                detectedBlocks.forEach(b => { if(selectedBlockIds.has(b.id) && !b.isSystemZone) { b.dataType = typeMap[e.key]; changed = true; } });
                if(changed) { renderMarkers(); renderTable(); updateActionBtnState(); showToast(`已快速切換為 ${getTypeString(typeMap[e.key])} 類型`, 'success'); }
                return;
            }

            if (e.ctrlKey && (e.key === 'z' || e.key === 'Z')) { e.preventDefault(); undo(); return; }
            if (e.ctrlKey && (e.key === 'y' || e.key === 'Y')) { e.preventDefault(); redo(); return; }
            if (e.ctrlKey && (e.key === 'c' || e.key === 'C')) { 
                e.preventDefault(); if (selectedBlockIds.size > 0) { clipboard = JSON.parse(JSON.stringify(detectedBlocks.filter(b => selectedBlockIds.has(b.id)))); showToast(`已複製 ${clipboard.length} 個物件`, "success"); } return; 
            }
            if (e.ctrlKey && (e.key === 'v' || e.key === 'V')) { 
                e.preventDefault(); if (clipboard.length > 0) {
                    saveState(); const newSelections = new Set();
                    clipboard.forEach(b => {
                        let newObj = { ...b, xmin: Math.min(1000, b.xmin+20), xmax: Math.min(1000, b.xmax+20), ymin: Math.min(1000, b.ymin+20), ymax: Math.min(1000, b.ymax+20) };
                        if(b.isSystemZone) { newObj.id = 'sys-' + Math.random().toString(36).substr(2, 9); } else { newObj.id = 0; }
                        detectedBlocks.push(newObj); newSelections.add(newObj.id); 
                    });
                    selectedBlockIds = newSelections; reassignIDs(); updateUI(); showToast(`已貼上 ${clipboard.length} 個物件`, "success");
                } return; 
            }
            if (e.ctrlKey && e.key === '1') { e.preventDefault(); setLockStateSelected(true); return; }
            if (e.ctrlKey && e.key === '2') { e.preventDefault(); setLockStateSelected(false); return; }
            if(e.code === 'Space') { e.preventDefault(); if(!e.repeat && toolMode !== 'pan') { previousToolMode = toolMode; setToolMode('pan'); } }
            else if (!e.ctrlKey && (e.key === 'v' || e.key === 'V')) setToolMode('select');
            else if (e.key === 'h' || e.key === 'H') setToolMode('pan');
            else if (e.key === 'r' || e.key === 'R') setToolMode('draw-range');
            else if (e.key === 'm' || e.key === 'M') setToolMode('draw-mask');
            else if (e.key === 'd' || e.key === 'D') { if (e.ctrlKey) { e.preventDefault(); duplicateSelected(); } else setToolMode('draw'); }
            else if (selectedBlockIds.size > 0 && (e.key === 'Delete' || e.key === 'Backspace')) { e.preventDefault(); deleteSelected(); }
            
            if(selectedBlockIds.size > 0 && ['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) {
                e.preventDefault(); let dx=0, dy=0; const step = e.shiftKey ? 10 : 1;
                if(e.key==='ArrowUp') dy=-step; else if(e.key==='ArrowDown') dy=step; else if(e.key==='ArrowLeft') dx=-step; else if(e.key==='ArrowRight') dx=step;
                if(!actionStateSaved) { saveState(); actionStateSaved = true; }
                detectedBlocks.forEach(b => { if(selectedBlockIds.has(b.id) && !b.isLocked) { b.xmin = Math.max(0, b.xmin + dx); b.xmax = Math.min(1000, b.xmax + dx); b.ymin = Math.max(0, b.ymin + dy); b.ymax = Math.min(1000, b.ymax + dy); } });
                renderMarkers();
            }
        });
        
        window.addEventListener('keyup', (e) => { 
            if(e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return; 
            if(e.code === 'Space') { e.preventDefault(); setToolMode(previousToolMode); }
            if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) { actionStateSaved = false; }
        });

        document.getElementById('zoomInBtn').onclick = () => setZoom(currentZoom + 0.1, canvasArea.clientWidth/2, canvasArea.clientHeight/2); 
        document.getElementById('zoomOutBtn').onclick = () => setZoom(currentZoom - 0.1, canvasArea.clientWidth/2, canvasArea.clientHeight/2); 
        document.getElementById('zoomResetBtn').onclick = () => setZoom(1.0, canvasArea.clientWidth/2, canvasArea.clientHeight/2);
        
        function setZoom(val, cx, cy) {
            if (!currentSingleBase64) return; 
            const relX = (cx + canvasArea.scrollLeft) / currentZoom; const relY = (cy + canvasArea.scrollTop) / currentZoom;
            currentZoom = Math.max(0.1, Math.min(val, 5.0));
            document.getElementById('zoomResetBtn').innerText = Math.round(currentZoom * 100) + '%';
            canvas.style.width = (referenceImg.width * currentZoom) + 'px'; canvas.style.height = (referenceImg.height * currentZoom) + 'px';
            canvasArea.scrollLeft = relX * currentZoom - cx; canvasArea.scrollTop = relY * currentZoom - cy;
        }

        canvasArea.addEventListener('wheel', (e) => {
            if (e.altKey && currentSingleBase64) {
                e.preventDefault(); const rect = canvasArea.getBoundingClientRect(); const zoomDelta = Math.sign(e.deltaY) < 0 ? 0.1 : -0.1;
                setZoom(currentZoom + zoomDelta, e.clientX - rect.left, e.clientY - rect.top);
            }
        }, { passive: false });

        let panStartX, panStartY, scrollStartX, scrollStartY;
        canvasArea.addEventListener('mousedown', (e) => {
            if (toolMode === 'pan' || e.button === 1) {
                isDragging = true; canvasArea.classList.add('is-panning');
                panStartX = e.clientX; panStartY = e.clientY; scrollStartX = canvasArea.scrollLeft; scrollStartY = canvasArea.scrollTop;
            }
        });

        overlayLayer.addEventListener('mousedown', (e) => {
            if(!currentSingleBase64 || toolMode === 'pan' || e.button === 1) return;
            const rect = overlayLayer.getBoundingClientRect(), startX = Math.max(0, Math.min(1000, ((e.clientX - rect.left) / rect.width) * 1000)), startY = Math.max(0, Math.min(1000, ((e.clientY - rect.top) / rect.height) * 1000));
            actionStateSaved = false;
            
            if(toolMode.startsWith('draw')) {
                isDrawing = true; dragStartCoords = { x: startX, y: startY };
                drawTempDiv = document.createElement('div'); 
                if(toolMode === 'draw-range') drawTempDiv.className = 'border-2 border-dashed border-red-500 bg-red-500/20 absolute z-[300] pointer-events-none';
                else if(toolMode === 'draw-mask') drawTempDiv.className = 'border-2 border-solid border-slate-600 bg-black/60 absolute z-[300] pointer-events-none';
                else drawTempDiv.className = 'border-2 border-dashed border-blue-500 bg-blue-500/20 absolute z-[300] pointer-events-none';
                overlayLayer.appendChild(drawTempDiv);
            } else if (toolMode === 'select') {
