        async function smartProcessImage(imgElement, loadingPrefix = "", masks = [], isExhaustive = false, targetType = 'all') {
            const aspect = imgElement.height / imgElement.width, maxAspect = 2.0; 
            
            if (aspect <= maxAspect) { 
                if(loadingPrefix) document.getElementById('loadingText').innerText = `${loadingPrefix}`; 
                if (masks.length > 0) {
                    const tempCanvas = document.createElement('canvas');
                    tempCanvas.width = imgElement.width; tempCanvas.height = imgElement.height;
                    const tCtx = tempCanvas.getContext('2d');
                    tCtx.drawImage(imgElement, 0, 0);
                    tCtx.fillStyle = '#000000';
                    masks.forEach(m => {
                        tCtx.fillRect(
                            (m.xmin / 1000) * imgElement.width, 
                            (m.ymin / 1000) * imgElement.height, 
                            ((m.xmax - m.xmin) / 1000) * imgElement.width, 
                            ((m.ymax - m.ymin) / 1000) * imgElement.height
                        );
                    });
                    return await fetchGeminiDetections(tempCanvas.toDataURL('image/jpeg', 0.9).split(',')[1], 0, isExhaustive, targetType);
                } else {
                    return await fetchGeminiDetections(getBase64FromImage(imgElement).split(',')[1], 0, isExhaustive, targetType); 
                }
            }
            
            if(!loadingPrefix) showToast("啟動長圖切割技術...", "info");
            const chunkH = imgElement.width * maxAspect, slices = Math.ceil(imgElement.height / chunkH); let allDetections = [];
            const tempCanvas = document.createElement('canvas'); tempCanvas.width = imgElement.width; tempCanvas.height = chunkH; const tCtx = tempCanvas.getContext('2d');
            for (let i = 0; i < slices; i++) {
                document.getElementById('loadingText').innerText = loadingPrefix ? `${loadingPrefix} [掃描切片 ${i+1}/${slices}]...` : `AI 視覺掃描中 [切片 ${i+1}/${slices}]...`;
                let yOffset = i * chunkH; if (yOffset + chunkH > imgElement.height && slices > 1) yOffset = imgElement.height - chunkH;
                tCtx.clearRect(0, 0, tempCanvas.width, tempCanvas.height); 
                tCtx.drawImage(imgElement, 0, yOffset, imgElement.width, chunkH, 0, 0, imgElement.width, chunkH);
                
                if (masks.length > 0) {
                    tCtx.fillStyle = '#000000';
                    masks.forEach(m => {
                        tCtx.fillRect(
                            (m.xmin / 1000) * imgElement.width, 
                            (m.ymin / 1000) * imgElement.height - yOffset, 
                            ((m.xmax - m.xmin) / 1000) * imgElement.width, 
                            ((m.ymax - m.ymin) / 1000) * imgElement.height
                        );
                    });
                }

                try {
                    const sliceDets = await fetchGeminiDetections(tempCanvas.toDataURL('image/jpeg', 0.9).split(',')[1], 0, isExhaustive, targetType);
                    sliceDets.forEach(det => {
                        const [ymin, xmin, ymax, xmax] = det.box_2d, rYMin = (ymin / 1000) * chunkH, rYMax = (ymax / 1000) * chunkH;
                        det.box_2d = [ Math.round(((rYMin + yOffset) / imgElement.height) * 1000), xmin, Math.round(((rYMax + yOffset) / imgElement.height) * 1000), xmax ]; allDetections.push(det);
                    });
                } catch (e) { console.error("切片處理失敗", i, e); }
                if (i < slices - 1) await new Promise(r => setTimeout(r, 1500)); 
            }
            let uniqueDetections = [];
            for (let d of allDetections) {
                let isDup = false; const cyd = (d.box_2d[0]+d.box_2d[2])/2, cxd = (d.box_2d[1]+d.box_2d[3])/2;
                for (let u of uniqueDetections) { const cyu = (u.box_2d[0]+u.box_2d[2])/2, cxu = (u.box_2d[1]+u.box_2d[3])/2; if (Math.abs(cyd-cyu)<10 && Math.abs(cxd-cxu)<10 && d.text === u.text) { isDup = true; break; } }
                if (!isDup) uniqueDetections.push(d);
            }
            return uniqueDetections;
        }

        // ==========================================
        // 核心升級：拓撲彈性網格引擎 (Topological Elastic Engine)
        // ==========================================
        function createElasticGrid(detections) {
            let globalShift = { dy: 0, dx: 0 }; 
            let strongAnchors = [];
            
            detectedBlocks.forEach(b => {
                if(b.isSystemZone || !b.text) return; 
                let tCy = (b.ymin + b.ymax)/2, tCx = (b.xmin + b.xmax)/2;
                let bestMatch = null, minDiff = 400; 
                detections.forEach((d, i) => {
                    if(d.text === b.text) {
                        let dCy = (d.box_2d[0]+d.box_2d[2])/2, dCx = (d.box_2d[1]+d.box_2d[3])/2;
                        let diff = Math.abs(dCy - tCy) + Math.abs(dCx - tCx);
                        let shapeDiff = Math.abs((d.box_2d[3]-d.box_2d[1]) - (b.xmax-b.xmin)) + Math.abs((d.box_2d[2]-d.box_2d[0]) - (b.ymax-b.ymin));
                        if(shapeDiff < 150 && diff < minDiff) { minDiff = diff; bestMatch = {dy: dCy-tCy, dx: dCx-tCx}; }
                    }
                });
                if(bestMatch) strongAnchors.push({cy: tCy, dx: bestMatch.dx, dy: bestMatch.dy});
            });

            if(strongAnchors.length < 2) {
                let dyList = [], dxList = [];
                backgroundAnchors.forEach(anc => {
                    const match = detections.find(d => d.text === anc.text);
                    if (match) { dyList.push((match.box_2d[0]+match.box_2d[2])/2 - (anc.box_2d[0]+anc.box_2d[2])/2); dxList.push((match.box_2d[1]+match.box_2d[3])/2 - (anc.box_2d[1]+anc.box_2d[3])/2); }
                });
                if (dyList.length >= 2) {
                    dyList.sort((a,b)=>a-b); dxList.sort((a,b)=>a-b); 
                    globalShift = { dy: dyList[Math.floor(dyList.length/2)], dx: dxList[Math.floor(dxList.length/2)] };
                }
            }

            strongAnchors.sort((a,b) => a.cy - b.cy);
            let filteredAnchors = [];
            strongAnchors.forEach(a => { 
                if(filteredAnchors.length === 0 || a.cy - filteredAnchors[filteredAnchors.length-1].cy > 20) { filteredAnchors.push(a); }
            });

            return function(origY) {
                if(filteredAnchors.length === 0) return globalShift;
                if(origY <= filteredAnchors[0].cy) return { dy: filteredAnchors[0].dy, dx: filteredAnchors[0].dx };
                if(origY >= filteredAnchors[filteredAnchors.length-1].cy) return { dy: filteredAnchors[filteredAnchors.length-1].dy, dx: filteredAnchors[filteredAnchors.length-1].dx };
                for(let j=0; j<filteredAnchors.length-1; j++) {
                    let A = filteredAnchors[j], B = filteredAnchors[j+1];
                    if(origY >= A.cy && origY <= B.cy) {
                        let ratio = (origY - A.cy) / (B.cy - A.cy);
                        return { dy: A.dy + ratio * (B.dy - A.dy), dx: A.dx + ratio * (B.dx - A.dx) };
                    }
                }
                return globalShift;
            };
        }

        // ======================= 掃描按鈕邏輯 (自動判斷) =======================
        
        async function performScan() {
            if(!currentSingleBase64) return;
            
            let maskBlocks = detectedBlocks.filter(b => b.isSystemZone && b.dataType === 'mask');
            let rangeBlocks = detectedBlocks.filter(b => b.isSystemZone && b.dataType === 'range');

            loading.style.display = 'flex'; 
            
            try {
                if (rangeBlocks.length > 0) {
                    // ==========================================
                    // 模式 A：【局部範圍限定掃描】
                    // ==========================================
                    document.getElementById('loadingTitle').innerText = "局部限定掃描中"; 
                    document.getElementById('loadingText').innerText = "Scanning targeted regions...";
                    
                    let detections = [];
                    for (let r of rangeBlocks) {
                        let typeName = r.targetType === 'text' ? '文字' : (r.targetType === 'image' ? '圖片' : '全部目標');
                        document.getElementById('loadingText').innerText = `正在深度挖掘 [${typeName}]...`;
                        try {
                            let rBox = [r.ymin, r.xmin, r.ymax, r.xmax];
                            let rBase64 = cropImageRegion(referenceImg, rBox, maskBlocks).split(',')[1];
                            let rImg = await new Promise(res => { let img = new Image(); img.onload = () => res(img); img.src = 'data:image/jpeg;base64,' + rBase64; });
                            let rDets = await smartProcessImage(rImg, `極限掃描 (${typeName})`, [], true, r.targetType || 'all');
                            rDets.forEach(d => {
                                let nyMin = r.ymin + (d.box_2d[0] / 1000) * (r.ymax - r.ymin);
                                let nxMin = r.xmin + (d.box_2d[1] / 1000) * (r.xmax - r.xmin);
                                let nyMax = r.ymin + (d.box_2d[2] / 1000) * (r.ymax - r.ymin);
                                let nxMax = r.xmin + (d.box_2d[3] / 1000) * (r.xmax - r.xmin);
                                detections.push({ text: d.text, type: d.type || (r.targetType === 'image' ? 'image' : 'text'), box_2d: [nyMin, nxMin, nyMax, nxMax] });
                            });
                        } catch(e) { console.error("Region scan failed", e); }
                    }

                    saveState();
                    let appendedCount = 0;

                    detections.forEach(d => {
                        let isOverlap = detectedBlocks.some(b => {
                            if (b.isSystemZone) return false;
                            let interY = Math.max(0, Math.min(b.ymax, d.box_2d[2]) - Math.max(b.ymin, d.box_2d[0]));
                            let interX = Math.max(0, Math.min(b.xmax, d.box_2d[3]) - Math.max(b.xmin, d.box_2d[1]));
                            if (interY <= 0 || interX <= 0) return false;
                            let areaD = (d.box_2d[2] - d.box_2d[0]) * (d.box_2d[3] - d.box_2d[1]);
                            return (interY * interX) / areaD > 0.5;
                        });

                        if (!isOverlap) {
                            detectedBlocks.push({ id: 0, isSystemZone: false, text: d.text, val: d.text, ymin: d.box_2d[0], xmin: d.box_2d[1], ymax: d.box_2d[2], xmax: d.box_2d[3], columnName: "", dataType: d.type || "text", isLocked: false, isManuallyNamed: false });
                            appendedCount++;
                        }
                    });

                    showToast(`局部限定掃描完成！於辨識區內追加 ${appendedCount} 個物件。<br><span class="text-[10px] opacity-80 mt-1 block">${getIconSVG('info', 'w-3 h-3 inline-block mr-1')}現有辨識框已維持原位不變</span>`, "success");

                } else {
                    // ==========================================
                    // 模式 B：【全域校正與追加】
                    // ==========================================
                    document.getElementById('loadingTitle').innerText = "二次拓撲校正中"; 
                    document.getElementById('loadingText').innerText = "Aligning & Appending...";
                    
                    let detections = await smartProcessImage(referenceImg, "", maskBlocks); 
                    saveState();

                    let usedDetections = new Set();
                    let updatedCount = 0, appendedCount = 0, purgedCount = 0;

                    let getElasticShift = createElasticGrid(detections);

                    const getIOU = (boxA, boxB) => {
                        const yA = Math.max(boxA[0], boxB[0]), xA = Math.max(boxA[1], boxB[1]);
                        const yB = Math.min(boxA[2], boxB[2]), xB = Math.min(boxA[3], boxB[3]);
                        const interArea = Math.max(0, yB - yA) * Math.max(0, xB - xA);
                        const areaA = (boxA[2] - boxA[0]) * (boxA[3] - boxA[1]);
                        const areaB = (boxB[2] - boxB[0]) * (boxB[3] - boxB[1]);
                        return interArea / (areaA + areaB - interArea);
                    };

                    detectedBlocks.forEach(b => {
                        if (b.isLocked) return;
                        
                        let shiftMin = getElasticShift(b.ymin);
                        let shiftMax = getElasticShift(b.ymax);
                        let predictedBox = [b.ymin + shiftMin.dy, b.xmin + shiftMin.dx, b.ymax + shiftMax.dy, b.xmax + shiftMax.dx];

                        if (b.isSystemZone) {
                            b.ymin = predictedBox[0]; b.xmin = predictedBox[1]; b.ymax = predictedBox[2]; b.xmax = predictedBox[3];
                            updatedCount++;
                            return;
                        }

                        let bestDet = null; let bestScore = -9999;
                        let tCy = (predictedBox[0] + predictedBox[2]) / 2, tCx = (predictedBox[1] + predictedBox[3]) / 2;
                        let tW = predictedBox[3] - predictedBox[1], tH = predictedBox[2] - predictedBox[0];

                        detections.forEach((d, i) => {
                            if (usedDetections.has(i)) return;
                            let dCy = (d.box_2d[0] + d.box_2d[2]) / 2, dCx = (d.box_2d[1] + d.box_2d[3]) / 2;
                            let dist = Math.sqrt(Math.pow(dCy - tCy, 2) + Math.pow(dCx - tCx, 2));
                            let totalShapeDiff = Math.abs((d.box_2d[3] - d.box_2d[1]) - tW) + Math.abs((d.box_2d[2] - d.box_2d[0]) - tH);

                            let isLandmark = (b.text && d.text && b.text === d.text);
                            if (dist > (isLandmark || totalShapeDiff < 30 ? 400 : 100)) return;

                            let iou = getIOU(predictedBox, d.box_2d);
                            let score = (iou * 800) - dist + (isLandmark ? 1000 : 0) + Math.max(0, 300 - totalShapeDiff * 3);

                            if (score > bestScore) { bestScore = score; bestDet = { d, i, dist, iou, totalShapeDiff }; }
                        });

                        if (bestDet && (bestDet.iou > 0.1 || bestDet.dist < 30 || (bestDet.totalShapeDiff < 20 && bestDet.dist < 200))) {
                            b.ymin = bestDet.d.box_2d[0]; b.xmin = bestDet.d.box_2d[1]; b.ymax = bestDet.d.box_2d[2]; b.xmax = bestDet.d.box_2d[3];
                            if (b.dataType === 'text') b.text = bestDet.d.text;
                            usedDetections.add(bestDet.i); updatedCount++;
                        } else {
                            b.ymin = predictedBox[0]; b.xmin = predictedBox[1]; b.ymax = predictedBox[2]; b.xmax = predictedBox[3];
                        }
                    });

                    let toDelete = new Set();
                    detectedBlocks.forEach(b => {
                        if (b.isSystemZone || b.isLocked) return;
                        let bCy = (b.ymin + b.ymax) / 2, bCx = (b.xmin + b.xmax) / 2;
                        if (maskBlocks.length > 0 && maskBlocks.some(m => bCy >= m.ymin && bCy <= m.ymax && bCx >= m.xmin && bCx <= m.xmax)) toDelete.add(b.id);
                    });
                    purgedCount = toDelete.size;
                    detectedBlocks = detectedBlocks.filter(b => !toDelete.has(b.id));

                    detections.forEach((d, i) => {
                        if (!usedDetections.has(i)) {
                            let dCy = (d.box_2d[0] + d.box_2d[2]) / 2, dCx = (d.box_2d[1] + d.box_2d[3]) / 2;
                            if (maskBlocks.length > 0 && maskBlocks.some(m => dCy >= m.ymin && dCy <= m.ymax && dCx >= m.xmin && dCx <= m.xmax)) return;

                            if (!detectedBlocks.some(b => {
                                let interY = Math.max(0, Math.min(b.ymax, d.box_2d[2]) - Math.max(b.ymin, d.box_2d[0]));
                                let interX = Math.max(0, Math.min(b.xmax, d.box_2d[3]) - Math.max(b.xmin, d.box_2d[1]));
                                if (interY <= 0 || interX <= 0) return false;
                                let areaD = (d.box_2d[2] - d.box_2d[0]) * (d.box_2d[3] - d.box_2d[1]);
                                return (interY * interX) / areaD > 0.5;
                            })) {
                                detectedBlocks.push({ id: 0, isSystemZone: false, text: d.text, val: d.text, ymin: d.box_2d[0], xmin: d.box_2d[1], ymax: d.box_2d[2], xmax: d.box_2d[3], columnName: "", dataType: d.type || "text", isLocked: false, isManuallyNamed: false });
                                appendedCount++;
                            }
                        }
                    });
                    
                    backgroundAnchors = detections.map(d => ({ text: d.text, box_2d: [...d.box_2d] }));
                    
                    let msg = `追加掃描完成！校正 ${updatedCount} 個辨識框`;
                    if (purgedCount > 0) msg += `，清除 ${purgedCount} 個雜訊`;
                    msg += `，追加 ${appendedCount} 個物件。`;
                    showToast(msg, "success");
                }

                document.getElementById('aiBadge').classList.add('hidden'); 
                selectedBlockIds.clear(); reassignIDs(); updateUI();
                if(!isLeftDrawerOpen) document.getElementById('leftDrawerToggle').click();
                
            } catch (err) { showToast("掃描失敗，請重試。", "error"); console.error(err); } finally { loading.style.display = 'none'; }
        }

        // 3. 處理「智慧判斷」掃描主按鈕的行為
        btnScan.onclick = () => {
            performScan();
        };

        btnExtract.onclick = async () => {
            const tplFields = detectedBlocks.filter(b => !b.isSystemZone && b.columnName);
            let maskBlocks = detectedBlocks.filter(b => b.isSystemZone && b.dataType === 'mask');
            
            if (batchFiles.length === 0 || tplFields.length === 0) return;
            
            const textFields = tplFields.filter(b => b.dataType === 'text');
            const imgFields = tplFields.filter(b => b.dataType === 'image' || b.dataType === 'screenshot');
            
            loading.style.display = 'flex'; document.getElementById('loadingTitle').innerText = batchFiles.length > 1 ? "批量提取處理中" : "精準提取處理中"; document.getElementById('batchProgress').classList.remove('hidden');
            document.getElementById('aiBadge').classList.add('hidden');
            batchResults = []; let nextImg = null;

            for (let i = 0; i < batchFiles.length; i++) {
                const cFile = batchFiles[i];
                if (document.getElementById(`batch-file-${i-1}`)) document.getElementById(`batch-file-${i-1}`).classList.add('opacity-50');
                if (document.getElementById(`batch-file-${i}`)) { document.getElementById(`batch-file-${i}`).scrollIntoView({block: "nearest"}); }
                
                const cImg = nextImg || await new Promise((r,rj)=>{const rd=new FileReader();rd.onload=e=>{const img=new Image();img.onload=()=>r(img);img.src=e.target.result;};rd.readAsDataURL(cFile);});
                if (i+1 < batchFiles.length) { new Promise((r,rj)=>{const rd=new FileReader();rd.onload=e=>{const img=new Image();img.onload=()=>r(img);img.src=e.target.result;};rd.readAsDataURL(batchFiles[i+1]);}).then(img => nextImg = img); } else { nextImg = null; }
                document.getElementById('batchProgressBar').style.width = ((i/batchFiles.length)*100)+'%';

                try {
                    let rData = { "檔案名稱": cFile.name };
                    let getElasticShift = (y) => ({ dy: 0, dx: 0 });

                    if (textFields.length > 0) {
                        let dets = await smartProcessImage(cImg, `[${i+1}/${batchFiles.length}] ${cFile.name}`);
                        getElasticShift = createElasticGrid(dets);

                        let shiftedMasks = maskBlocks.map(m => {
                            let sMin = getElasticShift(m.ymin); let sMax = getElasticShift(m.ymax);
                            return { ymin: m.ymin + sMin.dy, xmin: m.xmin + sMin.dx, ymax: m.ymax + sMax.dy, xmax: m.xmax + sMax.dx };
                        });

                        document.getElementById('loadingText').innerText = `正在進行精準 OCR 辨識 [${i+1}/${batchFiles.length}]...`;
                        let parts = [{ text: `You are an expert data extraction AI. I am providing you with specifically targeted, closely cropped image regions. For each region, you MUST thoroughly and perfectly read EVERY SINGLE visible character, number, or symbol. Do NOT summarize or skip details; extract the exact literal text or data. Return ONLY a valid JSON object where keys are the EXACT field names provided.` }];

                        textFields.forEach(tpl => {
                            let sMin = getElasticShift(tpl.ymin); let sMax = getElasticShift(tpl.ymax);
                            const cropBox = [tpl.ymin + sMin.dy, tpl.xmin + sMin.dx, tpl.ymax + sMax.dy, tpl.xmax + sMax.dx];
                            const cropBase64 = cropImageRegion(cImg, cropBox, shiftedMasks).split(',')[1];
                            parts.push({ text: `Field Name: "${tpl.columnName}"` });
                            parts.push({ inlineData: { mimeType: "image/jpeg", data: cropBase64 } });
                        });

                        const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ contents: [{ parts: parts }], generationConfig: { responseMimeType: "application/json" } })
                        });

                        if (res.ok) {
                            const aiData = JSON.parse((await res.json()).candidates[0].content.parts[0].text);
                            textFields.forEach(tpl => {
                                let val = aiData[tpl.columnName];
                                rData[tpl.columnName] = val !== undefined ? (typeof val === 'object' ? JSON.stringify(val) : String(val)) : "";
                            });
                        } else {
                            textFields.forEach(tpl => rData[tpl.columnName] = "AI 辨識錯誤");
                        }
                    }

                    let shiftedMasksForImg = maskBlocks.map(m => {
                        let sMin = getElasticShift(m.ymin); let sMax = getElasticShift(m.ymax);
                        return { ymin: m.ymin + sMin.dy, xmin: m.xmin + sMin.dx, ymax: m.ymax + sMax.dy, xmax: m.xmax + sMax.dx };
                    });

                    imgFields.forEach(tpl => {
                        let sMin = getElasticShift(tpl.ymin); let sMax = getElasticShift(tpl.ymax);
                        const cropBox = [tpl.ymin + sMin.dy, tpl.xmin + sMin.dx, tpl.ymax + sMax.dy, tpl.xmax + sMax.dx];
                        rData[tpl.columnName] = cropImageRegion(cImg, cropBox, shiftedMasksForImg);
                    });

                    if (i === batchFiles.length - 1) {
                        detectedBlocks.forEach(b => {
                            if (b.columnName && rData[b.columnName] !== undefined && !b.isSystemZone) {
                                b.val = (b.dataType === 'image' || b.dataType === 'screenshot') ? "[圖片資料]" : rData[b.columnName];
                            }
                        });
                    }

                    batchResults.push(rData); updateFinalPreview(); updateUI();
                } catch (e) { console.error(e); }
            }
            loading.style.display = 'none'; document.getElementById('batchProgress').classList.add('hidden');
            if (document.getElementById(`batch-file-${batchFiles.length-1}`)) document.getElementById(`batch-file-${batchFiles.length-1}`).classList.add('opacity-50');
            updateActionBtnState(); 
            showToast(`提取完畢！共 ${batchResults.length} 筆資料。`, "success");
            
            if(!isBottomDrawerOpen) document.getElementById('bottomDrawerToggle').click();
        };

        function updateActionBtnState() {
            const hasTpl = detectedBlocks.some(b => !b.isSystemZone && b.columnName && b.columnName.trim() !== ""); 
            const hasImages = batchFiles.length > 0;
            document.getElementById('importConfigBtn').disabled = false;
            
            btnScan.disabled = !hasImages; 
            btnExtract.disabled = !(hasImages && hasTpl);

            const exportDropdownBtn = document.getElementById('exportDropdownBtn');
            if (hasTpl || batchResults.length > 0) { 
                exportDropdownBtn.disabled = false; 
                exportDropdownBtn.classList.remove('opacity-30', 'cursor-not-allowed'); 
            } else { 
                exportDropdownBtn.disabled = true; 
                exportDropdownBtn.classList.add('opacity-30', 'cursor-not-allowed'); 
            }
            
            document.getElementById('exportModelBtn').disabled = !hasTpl; document.getElementById('exportMapBtn').disabled = !hasTpl; document.getElementById('exportCsvBtn').disabled = batchResults.length === 0;
        }

        function updateFinalPreview() {
            const countLabel = `${batchResults.length} 列`;
            document.getElementById('previewCountDrawer').innerText = countLabel;
            
            const hRow = document.getElementById('previewTableHeader'), tbody = document.getElementById('previewTableBody');
            if (batchResults.length === 0) { hRow.innerHTML = '<th class="p-2 px-6 font-bold text-slate-400">等待資料擷取...</th>'; tbody.innerHTML = ''; return; }
            
            const fields = detectedBlocks.filter(b => !b.isSystemZone && b.columnName).map(b => b.columnName);
            const headers = ['檔案名稱', ...fields];
            
            hRow.innerHTML = headers.map(h => `<th class="p-2 px-4 font-bold text-slate-500 bg-slate-100 dark:bg-slate-800 border-b border-r border-slate-200 dark:border-slate-700">${h}</th>`).join('');
            
            const displayResults = batchResults.slice(-50);
            const startIndex = Math.max(0, batchResults.length - 50);

            tbody.innerHTML = displayResults.map((r, rowIdx) => {
                const actualIdx = startIndex + rowIdx;
                return `<tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50">` + headers.map(h => {
                    if (h === '檔案名稱') {
                        return `<td class="p-2 px-4 border-r border-slate-100 dark:border-slate-800 text-indigo-600 dark:text-indigo-400 font-bold align-middle"><div class="truncate max-w-[200px]" title='${(r[h]||"").replace(/'/g, "\\")}'>${r[h]!==undefined?r[h]:''}</div></td>`;
                    }
                    const val = r[h] !== undefined ? r[h] : '';
                    if (typeof val === 'string' && val.startsWith('data:image/')) {
                        return `<td class="p-1 px-4 border-r border-slate-100 dark:border-slate-800 align-middle"><img src="${val}" class="h-10 w-auto max-w-[120px] object-contain rounded shadow-sm border border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-900 cursor-zoom-in hover:scale-[3] hover:shadow-2xl transition-transform origin-left relative z-10" onclick="showImageModal(this.src)" title="點擊檢視大圖"></td>`;
                    } else {
                        return `<td class="p-1 px-4 border-r border-slate-100 dark:border-slate-800 text-slate-700 dark:text-slate-300 align-middle"><input type="text" value="${String(val).replace(/"/g, '&quot;')}" onchange="updateBatchResult(${actualIdx}, '${h}', this.value)" class="bg-transparent border-b border-transparent hover:border-slate-300 focus:border-indigo-400 outline-none w-full min-w-[80px] text-[11px] py-1 transition-colors" title="點擊可手動修正內容"></td>`;
                    }
                }).join('') + `</tr>`;
            }).join('');
            tbody.parentElement.parentElement.scrollTop = tbody.parentElement.parentElement.scrollHeight;
        }

        async function saveFileWithPrompt(content, defaultFilename, mimeType) {
            const fallbackDownload = () => {
                const blob = new Blob([content], { type: mimeType });
                const url = URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = url; a.download = defaultFilename;
                document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
                showToast("已自動下載檔案", "success");
            };
            if (window.showSaveFilePicker) {
                try {
                    const ext = defaultFilename.split('.').pop();
                    const handle = await window.showSaveFilePicker({ suggestedName: defaultFilename, types: [{ description: 'File', accept: { [mimeType]: [`.${ext}`] } }], });
                    const writable = await handle.createWritable(); await writable.write(content); await writable.close(); showToast("存檔成功", "success");
                } catch (err) { if (err.name === 'AbortError') return; console.warn("儲存對話框異常，改用備用下載", err); fallbackDownload(); }
            } else { fallbackDownload(); }
        }

        document.getElementById('exportCsvBtn').onclick = () => {
            const h = ['檔案名稱', ...detectedBlocks.filter(b => !b.isSystemZone && b.columnName).map(b => b.columnName)];
            const csv = "\uFEFF" + h.join(',') + "\n" + batchResults.map(r => h.map(x => {
                let val = r[x] || "";
                if (typeof val === 'string' && val.startsWith('data:image/')) val = "[圖片資料 Base64]";
                return `"${String(val).replace(/"/g, '""')}"`;
            }).join(',')).join('\n');
            saveFileWithPrompt(csv, `擷取_${Date.now()}.csv`, 'text/csv;charset=utf-8;');
        };

        document.getElementById('exportModelBtn').onclick = () => {
            const data = { 
                version: "16.33", 
                type: "picdraw_model", 
                fields: detectedBlocks.filter(b => !b.isSystemZone).map(b => ({ columnName: b.columnName, ymin: b.ymin, xmin: b.xmin, ymax: b.ymax, xmax: b.xmax, originalText: b.val || b.text, dataType: b.dataType, isLocked: b.isLocked, labelPos: b.labelPos, isManuallyNamed: b.isManuallyNamed })),
                zones: detectedBlocks.filter(b => b.isSystemZone).map(b => ({ dataType: b.dataType, targetType: b.targetType || 'all', ymin: b.ymin, xmin: b.xmin, ymax: b.ymax, xmax: b.xmax }))
            };
            saveFileWithPrompt(JSON.stringify(data, null, 2), "Picdraw模型.json", 'application/json');
        };

        document.getElementById('exportMapBtn').onclick = () => {
            const data = { version: "16.33", type: "crawler_map", fields: detectedBlocks.filter(b => !b.isSystemZone && b.columnName).map(b => ({ field: b.columnName, type: b.dataType, box: [b.ymin, b.xmin, b.ymax, b.xmax] })) };
            saveFileWithPrompt(JSON.stringify(data, null, 2), "爬蟲地圖.json", 'application/json');
        };

        document.getElementById('importConfigBtn').onclick = () => configInput.click();
        configInput.onchange = (e) => {
            if (!e.target.files[0]) return; const rd = new FileReader();
            rd.onload = (ev) => {
                try {
                    const data = JSON.parse(ev.target.result), fields = Array.isArray(data) ? data : (data.fields || []); 
                    const zones = data.zones || [];
                    saveState();
                    detectedBlocks = fields.map((item, i) => ({ id: i+1, isSystemZone: false, text: item.originalText?`[參考: ${item.originalText}]`:"(模板)", ymin: item.ymin, xmin: item.xmin, ymax: item.ymax, xmax: item.xmax, columnName: item.columnName || item.field, dataType: item.dataType || item.type || 'text', isLocked: item.isLocked || false, val: "等待【套用】...", isManuallyNamed: item.isManuallyNamed !== undefined ? item.isManuallyNamed : true, labelPos: item.labelPos }));
                    
                    zones.forEach(z => { detectedBlocks.push({ id: 'sys-' + Math.random().toString(36).substr(2, 9), isSystemZone: true, dataType: z.dataType, targetType: z.targetType || 'all', ymin: z.ymin, xmin: z.xmin, ymax: z.ymax, xmax: z.xmax, isLocked: false }); });
                    
                    detectedBlocks.forEach(b => { if (!b.isSystemZone && (b.dataType === 'range' || b.dataType === 'mask')) { b.isSystemZone = true; b.id = 'sys-' + Math.random().toString(36).substr(2, 9); b.targetType = 'all'; } });

                    document.getElementById('aiBadge').classList.add('hidden'); selectedBlockIds.clear(); reassignIDs(); updateUI(); showToast(`載入成功！共 ${fields.length} 個節點。`, "success");
                    if(!isLeftDrawerOpen) document.getElementById('leftDrawerToggle').click();
                } catch (err) { showToast("讀取失敗，格式錯誤", "error"); } configInput.value = "";
            }; rd.readAsText(e.target.files[0]);
        };
        
        // 初始時觸發一次左側抽屜排版
        if (isLeftDrawerOpen) document.getElementById('canvasArea').style.left = '320px';
        updateActionBtnState();
    </script>
</body>
