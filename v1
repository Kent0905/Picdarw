        .label-top::after { content: ''; position: absolute; top: calc(100% + 18px); left: calc(50% - 2.5px); width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

        .label-bottom { left: 50%; transform: translateX(-50%); bottom: 100%; margin-top: 20px; }
        .label-bottom::before { content: ''; position: absolute; bottom: 100%; left: 50%; width: 1px; height: 20px; border-left: 1px solid currentColor; }
        .label-bottom::after { content: ''; position: absolute; bottom: calc(100% + 18px); left: calc(50% - 2.5px); width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

        .locked-marker { background-image: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(0,0,0,0.05) 5px, rgba(0,0,0,0.05) 10px); border-style: dashed !important; border-width: 2px !important; opacity: 0.8; z-index: 10 !important; pointer-events: none !important; }
