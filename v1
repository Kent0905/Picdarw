        /* === HUD Blueprint 教學氣泡系統 === */
        #hintOverlay { position: fixed; inset: 0; background: rgba(10, 15, 30, 0.85); backdrop-filter: blur(3px); z-index: 5000; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
        body.show-hints #hintOverlay { opacity: 1; pointer-events: auto; cursor: help; }
        body.show-hints nav, body.show-hints #leftDrawer, body.show-hints #bottomDrawer, body.show-hints #leftDrawerToggle { z-index: 5001 !important; }

        body.show-hints button, body.show-hints label { opacity: 1 !important; }
        body.show-hints nav button, body.show-hints nav label, body.show-hints #leftDrawerToggle, body.show-hints #bottomDrawerToggle { filter: drop-shadow(0 0 6px rgba(56, 189, 248, 0.8)) brightness(1.2); transition: filter 0.3s; }

        .hint-wrap { position: absolute; left: 50%; width: 0; height: 0; opacity: 0; z-index: 5010; transition: opacity 0.3s; pointer-events: none; }
        body.show-hints .hint-wrap { opacity: 1; }
        
        .hint-content { position: absolute; bottom: 0; white-space: nowrap; background: rgba(15, 23, 42, 0.95); color: #38bdf8; border: 1px solid #38bdf8; padding: 5px 12px; border-radius: 6px; font-size: 11px; font-weight: 900; letter-spacing: 1px; box-shadow: 0 4px 15px rgba(56, 189, 248, 0.4); transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
        
        .pin-center { left: 50%; transform: translateX(-50%) translateY(10px); } body.show-hints .pin-center { transform: translateX(-50%) translateY(0); }
        .pin-left { left: -8px; transform: translateY(10px); } body.show-hints .pin-left { transform: translateY(0); }
        .pin-right { right: -8px; left: auto; transform: translateY(10px); } body.show-hints .pin-right { transform: translateY(0); }

        .hint-wrap::after { content: ''; position: absolute; left: 0; top: 0; width: 1.5px; background: #38bdf8; }
        .hint-wrap::before { content: ''; position: absolute; left: -3.5px; width: 8px; height: 8px; border-radius: 50%; background: #38bdf8; box-shadow: 0 0 10px #38bdf8; border: 1.5px solid #fff; }

        .h-lv1 { bottom: calc(100% + 15px); } .h-lv1::after { height: 15px; } .h-lv1::before { top: 15px; }
        .h-lv2 { bottom: calc(100% + 48px); } .h-lv2::after { height: 48px; } .h-lv2::before { top: 48px; }
        .h-lv3 { bottom: calc(100% + 81px); } .h-lv3::after { height: 81px; } .h-lv3::before { top: 81px; }
        .h-lv4 { bottom: calc(100% + 114px); } .h-lv4::after { height: 114px; } .h-lv4::before { top: 114px; }
        .h-lv5 { bottom: calc(100% + 147px); } .h-lv5::after { height: 147px; } .h-lv5::before { top: 147px; }
        .h-lv6 { bottom: calc(100% + 180px); } .h-lv6::after { height: 180px; } .h-lv6::before { top: 180px; }

        .hint-wrap-side { position: absolute; top: 50%; left: 100%; width: 0; height: 0; opacity: 0; z-index: 5010; transition: opacity 0.3s; pointer-events: none; }
        body.show-hints .hint-wrap-side { opacity: 1; }
