        async function fetchGeminiDetections(base64Data, retryCount = 0, isExhaustive = false, targetType = 'all') {
            let instruction = "";
            if (targetType === 'text') {
                instruction = "Analyze this image ONLY for text, numbers, symbols, and labels. Completely EXCLUDE photos, icons, and background graphics.";
            } else if (targetType === 'image') {
                instruction = "Analyze this image ONLY for distinct visual elements, icons, character portraits, and photos. Completely EXCLUDE any text, numbers, or words.";
            } else {
                instruction = "Analyze this image for text, distinct visual elements, icons, character portraits, photos, or graphical components. EXCLUDE UI frames, borders, background panels, empty boxes, or layout grids.";
            }

            const prompt = isExhaustive
                ? `This is a specifically targeted and closely cropped Region of Interest (ROI). You MUST EXHAUSTIVELY analyze it. ${instruction} Be extremely meticulous and do not miss any details. Return JSON: {"detections": [{"text": "<exact content or description>", "type": "<'text' or 'image'>", "box_2d": [ymin, xmin, ymax, xmax]}]}. Use 0-1000 coordinates. Separate numbers from labels properly.`
                : `${instruction} Return JSON: {"detections": [{"text": "<exact content or description>", "type": "<'text' or 'image'>", "box_2d": [ymin, xmin, ymax, xmax]}]}. Use 0-1000 coordinates. Separate numbers from labels properly.`;
            
            try {
                const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType: "image/png", data: base64Data } }] }], generationConfig: { responseMimeType: "application/json", responseSchema: { type: "OBJECT", properties: { detections: { type: "ARRAY", items: { type: "OBJECT", properties: { text: { type: "STRING" }, type: { type: "STRING", enum: ["text", "image"] }, box_2d: { type: "ARRAY", items: { type: "NUMBER" }, minItems: 4, maxItems: 4 } }, required: ["text", "type", "box_2d"] } } }, required: ["detections"] } } })
                });
                if (!res.ok) throw new Error(res.status); return JSON.parse((await res.json()).candidates[0].content.parts[0].text.replace(/```json|```/g, "")).detections;
            } catch (err) { if (retryCount < 3) { await new Promise(r => setTimeout(r, 1000 * Math.pow(2, retryCount))); return fetchGeminiDetections(base64Data, retryCount + 1, isExhaustive, targetType); } throw err; }
        }

        async function fetchGeminiDataMapper(detections, mapSchema, retryCount = 0) {
            const prompt = `You are an intelligent data extraction assistant. Map the provided 'raw_detections' to the 'schema'.\nschema:\n${JSON.stringify(mapSchema, null, 2)}\nraw_detections:\n${JSON.stringify(detections)}\nRules:\n1. For 'text' type, find closest semantic and spatial match near 'expected_box'.\n2. For 'image' type, find bounding box of visual element that best fits 'expected_box' area.\n3. ONLY output a JSON object where keys are the 'field_name's.`;
            try {
                const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }], generationConfig: { responseMimeType: "application/json" } })
                });
                if (!res.ok) throw new Error(res.status); return JSON.parse((await res.json()).candidates[0].content.parts[0].text);
            } catch (err) { if (retryCount < 2) { await new Promise(r => setTimeout(r, 1000)); return fetchGeminiDataMapper(detections, mapSchema, retryCount + 1); } throw err; }
        }

        const getBase64FromImage = (img) => { const c=document.createElement('canvas'); c.width=img.width; c.height=img.height; c.getContext('2d').drawImage(img,0,0); return c.toDataURL('image/jpeg', 0.9); };
        
        function cropImageRegion(img, box, masks = []) {
            const canvas = document.createElement('canvas');
            const absY = Math.max(0, (box[0] / 1000) * img.height);
            const absX = Math.max(0, (box[1] / 1000) * img.width);
            const absH = Math.max(1, ((box[2] - box[0]) / 1000) * img.height);
            const absW = Math.max(1, ((box[3] - box[1]) / 1000) * img.width);
            canvas.width = absW; canvas.height = absH;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, absX, absY, absW, absH, 0, 0, absW, absH);
            
            if (masks.length > 0) {
                ctx.fillStyle = '#000000';
                masks.forEach(m => {
                    const mY = (m.ymin / 1000) * img.height - absY;
                    const mX = (m.xmin / 1000) * img.width - absX;
                    const mH = ((m.ymax - m.ymin) / 1000) * img.height;
                    const mW = ((m.xmax - m.xmin) / 1000) * img.width;
                    ctx.fillRect(mX, mY, mW, mH);
                });
            }
            return canvas.toDataURL('image/jpeg', 0.9);
        }

