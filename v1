        .label-right::after { content: ''; position: absolute; right: calc(100% + 18px); top: calc(50% - 2.5px); width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
        
        .label-left { top: 50%; transform: translateY(-50%); right: 100%; margin-right: 20px; }
        .label-left::before { content: ''; position: absolute; left: 100%; top: 50%; width: 20px; height: 1px; border-top: 1px solid currentColor; }
        .label-left::after { content: ''; position: absolute; left: calc(100% + 18px); top: calc(50% - 2.5px); width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

        .label-top { left: 50%; transform: translateX(-50%); bottom: 100%; margin-bottom: 20px; }
