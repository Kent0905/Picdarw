        .hint-wrap-side .hint-content { left: 45px; top: -14px; transform: translateX(10px) translateY(0); bottom: auto; }
        body.show-hints .hint-wrap-side .hint-content { transform: translateX(0) translateY(0); }
    </style>
</head>
